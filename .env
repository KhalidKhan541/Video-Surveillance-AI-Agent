# ╔══════════════════════════════════════════════════════════╗
# ║        VIDEO SURVEILLANCE AGENT — CONFIGURATION         ║
# ╠══════════════════════════════════════════════════════════╣
# ║  Paste your Groq API key below to enable LLM-powered   ║
# ║  anomaly reasoning. Get one at: https://console.groq.com║
# ╚══════════════════════════════════════════════════════════╝

# ===================================
#   PASTE YOUR GROQ API KEY BELOW
# ===================================
GROQ_API_KEY=your_groq_api_key_here

# ===================================
#   MODEL CONFIGURATION (Optional)
# ===================================
# Available models: llama-3.3-70b-versatile, mixtral-8x7b-32768, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# ===================================
#   VIDEO SOURCE (Optional)
# ===================================
# Use 0 for webcam, or a path like "video.mp4" or RTSP URL
VIDEO_SOURCE=0

# ===================================
#   YOLO MODEL (Optional)
# ===================================
# Options: yolov8n.pt (fastest), yolov8s.pt, yolov8m.pt, yolov8l.pt, yolov8x.pt (most accurate)
YOLO_MODEL=yolov8n.pt
